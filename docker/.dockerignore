# Exclude node_modules from Docker build context
node_modules/
**/node_modules/

# Exclude git files
.git/
.gitignore

# Exclude build artifacts
dist/
build/
.next/
out/

# Exclude local environment files
.env
.env.local
.env.*.local

# Exclude logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Exclude OS files
.DS_Store
Thumbs.db

# Exclude IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Exclude test coverage
coverage/
.nyc_output/

# Exclude temporary files
*.tmp
*.temp
