# ============================================================================
# Anthropic API Configuration
# ============================================================================
# Choose ONE configuration below based on your setup:

# OPTION 1: Standard Anthropic API (for customers)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# OPTION 2: Salesforce LLM Gateway Express (for internal Salesforce development)
# Uncomment these lines and comment out ANTHROPIC_API_KEY above
# Get your API key from: https://docs.internal.salesforce.com/ai/express-llm-gateway/
# ANTHROPIC_AUTH_TOKEN=your_api_key_here
# ANTHROPIC_BEDROCK_BASE_URL=https://eng-ai-model-gateway.sfproxy.devx-preprod.aws-esvc1-useast2.aws.sfdc.cl/bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_SKIP_BEDROCK_AUTH=1
# NODE_TLS_REJECT_UNAUTHORIZED=0  # Only for internal endpoints with self-signed certs

# ============================================================================
# SFRA Source Configuration
# ============================================================================
# Path to your storefront-reference-architecture checkout
# Used for ISML template discovery during migration setup
SFRA_SOURCE=/path/to/storefront-reference-architecture

# Common template base path (relative to SFRA_SOURCE)
# Default: cartridges/app_storefront_base/cartridge/templates/default
# SFRA_TEMPLATE_BASE=cartridges/app_storefront_base/cartridge/templates/default

# ============================================================================
# Optional: Migration Configuration
# ============================================================================
# PLAN_FILE=/workspace/migration-plan.md
# WORKER_ID=default-worker
